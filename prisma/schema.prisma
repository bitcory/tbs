generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  STAFF
  SUPER_ADMIN
}

enum ClassType {
  ZERO
  UP
  PRO
}

enum EnrollmentStatus {
  APPLIED
  ATTENDED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  nickname      String?   @unique
  email         String?   @unique
  phone         String?
  emailVerified DateTime?
  image         String?

  role          Role      @default(USER)
  stepAccess    Int[]     @default([])
  onboarded     Boolean   @default(false)

  privacyAgreedAt    DateTime?
  marketingOptIn     Boolean   @default(false)
  marketingAgreedAt  DateTime?

  bankName           String?
  bankAccount        String?
  accountHolder      String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  consentLogs ConsentLog[]

  mainSessions      ClassSession[] @relation("MainInstructor")
  assistantSessions ClassSession[] @relation("AssistantInstructor")
  createdSessions   ClassSession[] @relation("ClassSessionCreator")
  enrollments       Enrollment[]
}

model ConsentLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // "privacy" | "marketing"
  action    String   // "granted" | "revoked"
  source    String?  // "onboarding" | "profile_edit" | ...
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId, type])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ClassSession {
  id                    String    @id @default(cuid())
  startAt               DateTime
  classType             ClassType
  stepLevel             Int       @default(1)
  mainInstructorId      String?
  assistantInstructorId String?
  createdById           String?
  note                  String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  mainInstructor      User? @relation("MainInstructor", fields: [mainInstructorId], references: [id], onDelete: SetNull)
  assistantInstructor User? @relation("AssistantInstructor", fields: [assistantInstructorId], references: [id], onDelete: SetNull)
  createdBy           User? @relation("ClassSessionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  enrollments         Enrollment[]

  @@index([startAt])
  @@index([mainInstructorId])
  @@index([assistantInstructorId])
  @@index([createdById])
}

model Enrollment {
  id        String           @id @default(cuid())
  sessionId String
  userId    String
  status    EnrollmentStatus @default(APPLIED)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  session ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId])
}

model PricingConfig {
  id             String    @id @default(cuid())
  classType      ClassType
  stepLevel      Int       @default(0)
  pricePerPerson Int
  toolbShare     Float     @default(0.50)
  mainShare      Float     @default(0.35)
  assistantShare Float     @default(0.15)
  updatedAt      DateTime  @updatedAt
  updatedById    String?

  @@unique([classType, stepLevel])
}
